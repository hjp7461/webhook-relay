              { "color": "red", "value": 100 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "webhook_relay_queue_depth{queue=\"webhook-delivery-dlq\",job_state=\"completed\"}",
          "legendFormat": "dlq total",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "DLQ 적재율 (1h)",
      "description": "max_attempts_exceeded / non_retriable / stalled_loss_recovered 분류별.",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" } },
          "unit": "ops"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(webhook_relay_dlq_jobs_total[5m]))",
          "legendFormat": "{{reason}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 3,
      "type": "piechart",
      "title": "DLQ 분류 비율",
      "description": "1시간 누적 비율.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true, "values": ["percent"] }
      },
      "fieldConfig": { "defaults": { "mappings": [] }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(webhook_relay_dlq_jobs_total[1h]))",
          "legendFormat": "{{reason}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ]
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "DLQ 도달 시도 수 분포",
