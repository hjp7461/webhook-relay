# webhook-relay 환경변수 템플릿.
# 실제 값을 채워 .env 로 복사해 사용한다. .env 는 .gitignore 에 의해 추적되지 않는다.
# 키 출처: docs/prd/05-api-and-contracts.md §8 + docs/plan/00-decisions-needed.md 결정 잠금.
#
# 본 마일스톤(M1)에서는 어느 코드도 이 파일을 읽지 않는다. M2 이후 demo/config.ts 가
# Zod 로 파싱한다. 필수 시크릿(WEBHOOK_HMAC_SECRET, API_BEARER_TOKEN)이 누락되면
# 부트스트랩이 즉시 종료된다(fail-fast).

# ---------- 1단계 (M2 MVP) ----------
REDIS_URL=redis://localhost:6379
# 0 = OS 가 빈 포트 자동 할당(테스트/임시 실행에 유용). 기본 3000.
PORT=3000
LOG_LEVEL=info

# 작업 등록 API 인증 (Bearer). 최소 32 bytes. (PLAN Q-API-1)
# Generate with: openssl rand -hex 32  # produces 64 hex chars = 32 bytes
API_BEARER_TOKEN=

# 수신자 URL 의 private CIDR 허용 여부. true=허용, false=차단. (PLAN Q-SEC-1)
ALLOW_PRIVATE_TARGETS=true

# 페이로드 / 송신 타임아웃
WEBHOOK_MAX_PAYLOAD_BYTES=65536
WEBHOOK_DELIVERY_TIMEOUT_MS=5000

# 큐 이름. constants.ts 와 동기화되어야 한다.
QUEUE_NAME=webhook-delivery

# Redis 재연결 백오프
REDIS_RECONNECT_BASE_MS=200
REDIS_RECONNECT_MAX_MS=10000

# 워커 동시성
WORKER_CONCURRENCY=5

# ---------- 2단계 (M3 이후) ----------
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BACKOFF_BASE_MS=1000

# HMAC 서명 시크릿. 미설정 시 시작 거부(fail-fast).
# Generate with: openssl rand -hex 32  # produces 64 hex chars = 32 bytes
WEBHOOK_HMAC_SECRET=
WEBHOOK_HMAC_HEADER=X-Webhook-Signature

DLQ_NAME=webhook-delivery-dlq
STALLED_INTERVAL_MS=30000
MAX_STALLED_COUNT=1
SHUTDOWN_TIMEOUT_MS=30000

# 서비스 모드 — API/Worker 분리(컴포즈 --scale worker=N 용). 기본 'all'.
# SERVICE_MODE=all  # all | api | worker (default: all)

# ---------- 3단계 (M-OBS-1) ----------
# 워커 모드 전용 /metrics HTTP 포트 (Q-OBS-3 a). SERVICE_MODE=worker 일 때
# 본 포트로 Prometheus scrape 가능.
WORKER_METRICS_PORT=3001
